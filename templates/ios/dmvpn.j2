! ============================================================
! DMVPN Phase 2 Configuration — {{ hostname }} ({{ role | upper }})
! ============================================================
hostname {{ hostname }}
!
! --- Crypto (IKEv2 / IPsec) ---
crypto isakmp policy 10
 encr aes 256
 hash sha256
 authentication pre-share
 group 14
!
crypto isakmp key {{ nhrp_key }} address 0.0.0.0
!
crypto ipsec transform-set DMVPN-TS esp-aes 256 esp-sha256-hmac
 mode transport
!
crypto profile DMVPN-PROFILE
 set transform-set DMVPN-TS
!
! --- Tunnel Interface ---
interface Tunnel0
 description DMVPN {{ role | upper }}
 ip address {{ tunnel_ip }} {{ tunnel_mask }}
 ip nhrp network-id {{ nhrp_network_id }}
 ip nhrp authentication {{ nhrp_key }}
{% if role == 'hub' %}
 ip nhrp map multicast dynamic
 tunnel mode gre multipoint
{% else %}
 ip nhrp map {{ hub_tunnel_ip }} {{ hub_public_ip }}
 ip nhrp map multicast {{ hub_public_ip }}
 ip nhrp nhs {{ hub_tunnel_ip }}
 tunnel mode gre multipoint
{% endif %}
 tunnel source {{ tunnel_source }}
 tunnel protection ipsec profile DMVPN-PROFILE
!
! --- OSPF over DMVPN ---
router ospf {{ ospf_process }}
{% if role == 'hub' %}
 network {{ tunnel_ip }} 0.0.0.255 area 0
{% else %}
 network {{ tunnel_ip }} 0.0.0.255 area 0
{% endif %}
!
