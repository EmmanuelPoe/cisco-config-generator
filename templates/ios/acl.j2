! ============================================================
! ACL Configuration — {{ hostname }}
! ============================================================
hostname {{ hostname }}
!
{% if acl_type == 'extended' %}
ip access-list extended {{ acl_name }}
{% for rule in rules %}
{% if rule.remark is defined and rule.remark %}
 remark {{ rule.remark }}
{% endif %}
{% if rule.dst_port is defined and rule.dst_port %}
 {{ rule.action }} {{ rule.protocol }} {{ rule.src }} {{ rule.dst }} eq {{ rule.dst_port }}
{% else %}
 {{ rule.action }} {{ rule.protocol }} {{ rule.src }} {{ rule.dst }}
{% endif %}
{% endfor %}
{% else %}
ip access-list standard {{ acl_name }}
{% for rule in rules %}
{% if rule.remark is defined and rule.remark %}
 remark {{ rule.remark }}
{% endif %}
 {{ rule.action }} {{ rule.src }}
{% endfor %}
{% endif %}
!
{% if apply_to %}
interface {{ apply_to.split()[0] }}
 ip access-group {{ acl_name }} {{ apply_to.split()[1] }}
!
{% endif %}
