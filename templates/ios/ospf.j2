! ============================================================
! OSPF Configuration — {{ hostname }}
! ============================================================
hostname {{ hostname }}
!
router ospf {{ process_id }}
 router-id {{ router_id }}
{% for net in networks %}
 network {{ net.network }} {{ net.wildcard }} area {{ net.area }}
{% endfor %}
{% for iface in passive_interfaces %}
 passive-interface {{ iface }}
{% endfor %}
{% if default_route %}
 default-information originate always
{% endif %}
!
